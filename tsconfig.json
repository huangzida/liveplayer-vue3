{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "types": ["node", "vitest/globals", "happy-dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@docs/*": ["docs/*"],
      "@playground/*": ["playground/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "tests/**/*.ts", "docs/**/*.ts", "playground/**/*.ts", "playground/**/*.vue", "vite.config.ts", "vitest.config.ts"],
  "references": []
}